# Purpose: Template for the docker-compose.prod.yml environment file.
# Why important: Documents every variable the composed stack needs and wires the
#   API to the in-network postgres/redis service hostnames.
# Used by: copy to infra/docker/.env, then `docker compose -f docker-compose.prod.yml up`.
#
# NOTE: With NODE_ENV=production the API enforces HTTPS APP_BASE_URL and requires
# ALLOWED_ORIGINS. For a quick LOCAL smoke test set NODE_ENV=development.

# ---- Postgres (superuser + least-privilege roles created on first init) ----
POSTGRES_DB=pataspace
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-postgres-password
PATA_DB_APP_USER=pataspace_app
PATA_DB_APP_PASSWORD=replace-with-strong-app-password
PATA_DB_MIGRATOR_USER=pataspace_migrator
PATA_DB_MIGRATOR_PASSWORD=replace-with-strong-migrator-password

# ---- API runtime ----
NODE_ENV=production
APP_NAME=pataspace-api
PORT=3001
APP_BASE_URL=https://api.pataspace.example
ALLOWED_ORIGINS=https://app.pataspace.example
SWAGGER_ENABLED=false
SWAGGER_PATH=docs
SWAGGER_TITLE=PataSpace API
SWAGGER_DESCRIPTION=OpenAPI documentation for the PataSpace backend service.
SWAGGER_VERSION=0.1.0
HTTP_TRUST_PROXY=loopback
REQUEST_ID_HEADER=x-request-id

# Database URLs point at the compose "postgres" service.
DATABASE_URL=postgresql://pataspace_app:replace-with-strong-app-password@postgres:5432/pataspace
DATABASE_MIGRATION_URL=postgresql://pataspace_migrator:replace-with-strong-migrator-password@postgres:5432/pataspace
DATABASE_ADMIN_URL=postgresql://postgres:replace-with-strong-postgres-password@postgres:5432/pataspace

# Redis points at the compose "redis" service.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=replace-with-strong-redis-password
REDIS_DB=0

# ---- Secrets (replace all) ----
JWT_SECRET=replace-with-a-long-production-secret-value
JWT_REFRESH_SECRET=replace-with-a-long-production-refresh-secret
APP_ENCRYPTION_KEY=replace-with-a-32-char-minimum-encryption-key
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
REFRESH_TOKEN_TRANSPORT=json

# ---- OTP / rate limiting / queues ----
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=3
OTP_SANDBOX_CODE=123456
IDEMPOTENCY_TTL_SECONDS=86400
IDEMPOTENCY_IN_PROGRESS_TTL_SECONDS=120
RATE_LIMIT_DEFAULT_LIMIT=100
RATE_LIMIT_DEFAULT_TTL_SECONDS=60
QUEUE_PREFIX=pataspace

# ---- External integrations (sandbox by default) ----
SMS_PROVIDER=sandbox
STORAGE_PROVIDER=sandbox
MPESA_MODE=sandbox
AT_BASE_URL=https://api.africastalking.com
AWS_S3_BUCKET=pataspace-media
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=replace-with-aws-access-key
AWS_SECRET_ACCESS_KEY=replace-with-aws-secret-key
AWS_S3_PRESIGN_TTL_SECONDS=900
STORAGE_PUBLIC_BASE_URL=https://api.pataspace.example/sandbox-storage
STORAGE_CDN_BASE_URL=https://api.pataspace.example/sandbox-storage

# ---- Observability (docker-compose.observability.yml overlay) ----
# Bearer token protecting GET /metrics. REQUIRED in production: without it the
# API serves 404 on /metrics and Prometheus cannot scrape. Prometheus reads the
# same value, so setting it here wires both sides. Generate: openssl rand -hex 32
METRICS_TOKEN=replace-with-a-long-random-metrics-token
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-strong-grafana-password
# GRAFANA_ROOT_URL=https://grafana.pataspace.example
# GRAFANA_PORT=3005
# PROMETHEUS_PORT=9090
# ALERTMANAGER_PORT=9093
# PROMETHEUS_RETENTION_TIME=30d
# PROMETHEUS_RETENTION_SIZE=5GB
# Dedicated monitoring role instead of the superuser (see infra/observability/README.md):
# POSTGRES_EXPORTER_DSN=postgresql://pataspace_monitor:password@postgres:5432/pataspace?sslmode=disable

# ---- Compose image tags / ports (override to use pre-built GHCR images) ----
# API_IMAGE=ghcr.io/bizzy604/pataspace-api:latest
# WEB_IMAGE=ghcr.io/bizzy604/pataspace-web:latest
# ADMIN_IMAGE=ghcr.io/bizzy604/pataspace-admin:latest
# NGINX_IMAGE=ghcr.io/bizzy604/pataspace-nginx:latest
HTTP_PORT=80
ADMIN_PORT=8080
