# Purpose: Environment template for the VPS API-only stack (docker-compose.vps.yml).
# Why important: Documents every variable the stack needs; copy to .env and fill.
# Used by: docker-compose.vps.yml; Caddy reads API_DOMAIN from the env.
#
# INSTRUCTIONS
# 1. Copy to infra/docker/.env
# 2. Replace every REPLACE_* value.
# 3. Generate secrets with: openssl rand -base64 32
# 4. Run: docker compose -f docker-compose.vps.yml up -d

# ---- Domain (used by Caddyfile for auto-TLS) ----
API_DOMAIN=REPLACE_WITH_API_DOMAIN
# e.g. api.pataspace.com — point a DNS A-record at the VPS IP first.

# ---- GHCR image tag ----
API_IMAGE=ghcr.io/bizzy604/pataspace-api:latest

# ---- Postgres (least-privilege roles created on first boot) ----
POSTGRES_DB=pataspace
POSTGRES_USER=postgres
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
PATA_DB_APP_USER=pataspace_app
PATA_DB_APP_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
PATA_DB_MIGRATOR_USER=pataspace_migrator
PATA_DB_MIGRATOR_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ---- API runtime ----
NODE_ENV=production
APP_NAME=pataspace-api
PORT=3001
APP_BASE_URL=https://REPLACE_WITH_API_DOMAIN
ALLOWED_ORIGINS=*
SWAGGER_ENABLED=false
SWAGGER_PATH=docs
SWAGGER_TITLE=PataSpace API
SWAGGER_DESCRIPTION=OpenAPI documentation for the PataSpace backend service.
SWAGGER_VERSION=0.1.0
HTTP_TRUST_PROXY=loopback
REQUEST_ID_HEADER=x-request-id

# Database URLs — service names resolve inside the compose network.
DATABASE_URL=postgresql://pataspace_app:REPLACE_WITH_STRONG_PASSWORD@postgres:5432/pataspace
DATABASE_MIGRATION_URL=postgresql://pataspace_migrator:REPLACE_WITH_STRONG_PASSWORD@postgres:5432/pataspace
DATABASE_ADMIN_URL=postgresql://postgres:REPLACE_WITH_STRONG_PASSWORD@postgres:5432/pataspace

# Redis — inside the compose network.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
REDIS_DB=0

# ---- Auth secrets ----
JWT_SECRET=REPLACE_WITH_GENERATED_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_GENERATED_SECRET
APP_ENCRYPTION_KEY=REPLACE_WITH_32_CHAR_MIN_SECRET
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
REFRESH_TOKEN_TRANSPORT=json

# ---- Clerk (REQUIRED — the mobile app authenticates via Clerk) ----
CLERK_SECRET_KEY=REPLACE_WITH_CLERK_SECRET_KEY

# ---- OTP / rate limiting / queues ----
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=3
OTP_SANDBOX_CODE=123456
IDEMPOTENCY_TTL_SECONDS=86400
IDEMPOTENCY_IN_PROGRESS_TTL_SECONDS=120
RATE_LIMIT_DEFAULT_LIMIT=100
RATE_LIMIT_DEFAULT_TTL_SECONDS=60
QUEUE_PREFIX=pataspace

# ---- External integrations (sandbox for initial deploy) ----
SMS_PROVIDER=sandbox
STORAGE_PROVIDER=sandbox
MPESA_MODE=sandbox
AT_BASE_URL=https://api.africastalking.com
AT_USERNAME=sandbox
AT_API_KEY=sandbox-api-key
AWS_S3_BUCKET=pataspace-media
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=sandbox-access-key
AWS_SECRET_ACCESS_KEY=sandbox-secret-key
AWS_S3_PRESIGN_TTL_SECONDS=900
STORAGE_PUBLIC_BASE_URL=https://REPLACE_WITH_API_DOMAIN/sandbox-storage
STORAGE_CDN_BASE_URL=https://REPLACE_WITH_API_DOMAIN/sandbox-storage

# ---- M-Pesa sandbox ----
MPESA_BASE_URL=https://sandbox.safaricom.co.ke
MPESA_CONSUMER_KEY=sandbox-consumer-key
MPESA_CONSUMER_SECRET=sandbox-consumer-secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=sandbox-passkey
MPESA_CALLBACK_URL=https://REPLACE_WITH_API_DOMAIN/api/v1/payments/mpesa-callback
MPESA_INITIATOR_NAME=sandbox-initiator
MPESA_SECURITY_CREDENTIAL=sandbox-credential
MPESA_RESULT_URL=https://REPLACE_WITH_API_DOMAIN/api/v1/payments/mpesa-result
MPESA_TIMEOUT_URL=https://REPLACE_WITH_API_DOMAIN/api/v1/payments/mpesa-timeout
