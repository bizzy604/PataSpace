# Purpose: Environment template for the VPS API-only stack (docker-compose.vps.yml).
# Why important: Documents every variable the stack needs; copy to .env and fill.
# Used by: docker-compose.vps.yml; Caddy reads API_DOMAIN from the env.
#
# INSTRUCTIONS
# 1. Copy to infra/docker/.env
# 2. Replace every REPLACE_* value.
# 3. Generate secrets with: openssl rand -base64 32
# 4. Run: docker compose -f docker-compose.vps.yml up -d

# ---- Domain (used by Caddyfile for auto-TLS) ----
API_DOMAIN=REPLACE_WITH_API_DOMAIN
# e.g. api.pataspace.com — point a DNS A-record at the VPS IP first.

# ---- GHCR image tags (or local builds) ----
API_IMAGE=ghcr.io/bizzy604/pataspace-api:latest
WEB_IMAGE=ghcr.io/bizzy604/pataspace-web:latest

# ---- Web frontend ----
WEB_PUBLIC_API_URL=https://REPLACE_WITH_API_DOMAIN/api/v1
# NextAuth (Auth.js) — the web app's only identity layer; it delegates every
# real auth decision to the API via /auth/login|refresh|logout. Generate with:
# openssl rand -base64 32
AUTH_SECRET=REPLACE_WITH_GENERATED_SECRET
# Full public URL the admin console is served at (e.g. https://dalakenya.com)
# — NextAuth needs this off Vercel to build correct callback/redirect URLs.
AUTH_URL=https://REPLACE_WITH_WEB_DOMAIN

# ---- Postgres (least-privilege roles created on first boot) ----
POSTGRES_DB=pataspace
POSTGRES_USER=postgres
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
PATA_DB_APP_USER=pataspace_app
PATA_DB_APP_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
PATA_DB_MIGRATOR_USER=pataspace_migrator
PATA_DB_MIGRATOR_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ---- API runtime ----
NODE_ENV=production
APP_NAME=pataspace-api
PORT=3001
APP_BASE_URL=https://REPLACE_WITH_API_DOMAIN
ALLOWED_ORIGINS=https://dalakenya.com
SWAGGER_ENABLED=false
SWAGGER_PATH=docs
SWAGGER_TITLE=PataSpace API
SWAGGER_DESCRIPTION=OpenAPI documentation for the PataSpace backend service.
SWAGGER_VERSION=0.1.0
HTTP_TRUST_PROXY=loopback
REQUEST_ID_HEADER=x-request-id

# Database URLs — service names resolve inside the compose network.
DATABASE_URL=postgresql://pataspace_app:REPLACE_WITH_STRONG_PASSWORD@postgres:5432/pataspace
DATABASE_MIGRATION_URL=postgresql://pataspace_migrator:REPLACE_WITH_STRONG_PASSWORD@postgres:5432/pataspace
DATABASE_ADMIN_URL=postgresql://postgres:REPLACE_WITH_STRONG_PASSWORD@postgres:5432/pataspace

# Redis — inside the compose network.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
REDIS_DB=0

# ---- Auth secrets ----
JWT_SECRET=REPLACE_WITH_GENERATED_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_GENERATED_SECRET
APP_ENCRYPTION_KEY=REPLACE_WITH_32_CHAR_MIN_SECRET
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
REFRESH_TOKEN_TRANSPORT=json

# ---- OTP / rate limiting / queues ----
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=3
OTP_SANDBOX_CODE=123456
IDEMPOTENCY_TTL_SECONDS=86400
IDEMPOTENCY_IN_PROGRESS_TTL_SECONDS=120
RATE_LIMIT_DEFAULT_LIMIT=100
RATE_LIMIT_DEFAULT_TTL_SECONDS=60
QUEUE_PREFIX=pataspace

# ---- External integrations ----
# NODE_ENV=production refuses to boot with sandbox SMS or sandbox storage:
# sandbox SMS uses a fixed OTP, and sandbox storage mints upload URLs on a
# fake host (sandbox-storage.pataspace.local) so mobile uploads die at DNS.
SMS_PROVIDER=africastalking
MPESA_MODE=sandbox
AT_BASE_URL=https://api.africastalking.com
AT_USERNAME=REPLACE_WITH_AT_USERNAME
AT_API_KEY=REPLACE_WITH_AT_API_KEY

# ---- Storage (real S3 is mandatory in production) ----
STORAGE_PROVIDER=s3
AWS_S3_BUCKET=REPLACE_WITH_S3_BUCKET
AWS_REGION=REPLACE_WITH_AWS_REGION
AWS_ACCESS_KEY_ID=REPLACE_WITH_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_AWS_SECRET_ACCESS_KEY
AWS_S3_PRESIGN_TTL_SECONDS=900
# Leave STORAGE_PUBLIC_BASE_URL / STORAGE_CDN_BASE_URL unset to serve media
# straight from the bucket URL. Only set them when a CDN (e.g. CloudFront)
# fronts the bucket — never point them at /sandbox-storage; stored media
# URLs would 404 forever and production refuses to boot with that value.
# STORAGE_PUBLIC_BASE_URL=https://cdn.example.com
# STORAGE_CDN_BASE_URL=https://cdn.example.com

# ---- M-Pesa sandbox ----
MPESA_BASE_URL=https://sandbox.safaricom.co.ke
MPESA_CONSUMER_KEY=sandbox-consumer-key
MPESA_CONSUMER_SECRET=sandbox-consumer-secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=sandbox-passkey
# Set MPESA_CALLBACK_SECRET and append ?token=<the same secret> to every
# callback URL below: Safaricom cannot send headers, so the query token is
# the only credential that can arrive. Boot-time validation enforces this.
MPESA_CALLBACK_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
MPESA_CALLBACK_URL=https://REPLACE_WITH_API_DOMAIN/api/v1/payments/mpesa-callback?token=REPLACE_WITH_LONG_RANDOM_SECRET
MPESA_INITIATOR_NAME=sandbox-initiator
MPESA_SECURITY_CREDENTIAL=sandbox-credential
MPESA_RESULT_URL=https://REPLACE_WITH_API_DOMAIN/api/v1/payments/mpesa-b2c-callback?token=REPLACE_WITH_LONG_RANDOM_SECRET
MPESA_TIMEOUT_URL=https://REPLACE_WITH_API_DOMAIN/api/v1/payments/mpesa-b2c-timeout?token=REPLACE_WITH_LONG_RANDOM_SECRET

# ---- Observability (docker-compose.observability.yml overlay) ----
# Bearer token protecting GET /metrics. REQUIRED in production: without it the
# API serves 404 on /metrics and Prometheus cannot scrape. On the VPS the host
# nginx forwards every path to the API, so this token is what keeps
# https://<api-domain>/metrics private. Generate: openssl rand -hex 32
METRICS_TOKEN=REPLACE_WITH_GENERATED_SECRET
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
# GRAFANA_ROOT_URL=https://grafana.REPLACE_WITH_DOMAIN
# GRAFANA_PORT=3005
# PROMETHEUS_PORT=9090
# ALERTMANAGER_PORT=9093
# PROMETHEUS_RETENTION_TIME=30d
# PROMETHEUS_RETENTION_SIZE=5GB
# Dedicated monitoring role instead of the superuser (see infra/observability/README.md):
# POSTGRES_EXPORTER_DSN=postgresql://pataspace_monitor:password@postgres:5432/pataspace?sslmode=disable
