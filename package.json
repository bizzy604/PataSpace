{
  "name": "pataspace",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev:api": "pnpm --filter @pataspace/api start:dev",
    "dev:web": "pnpm --filter @pataspace/web dev",
    "dev:mobile": "pnpm --filter @pataspace/mobile start",
    "build": "pnpm -r --if-present build",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test",
    "standards:check": "node scripts/standards-check.mjs",
    "stitch:export:pataspace-login": "node scripts/export-stitch-project.mjs scripts/stitch-projects/pataspace-login.json"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "eslint": "^10.7.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.15.4"
  }
}
