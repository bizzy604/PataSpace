# Purpose: Local dev environment template for apps/web.
# Why important: Documents every variable the Next.js app reads — public
#   (inlined into the client bundle at build time) and server-only.
# Used by: copy to apps/web/.env, then `pnpm --filter @pataspace/web dev`.

# ---- API ----
# Public: read by both client and server code, inlined at build time.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1
# Server-only: preferred by NextAuth's Credentials provider and jwt-refresh
# callback (auth.ts / lib/api/auth.ts) when set — lets server-to-server calls
# reach the API over an internal network instead of the public URL above.
# Falls back to NEXT_PUBLIC_API_BASE_URL when unset, so local dev (where both
# processes run on localhost) can leave this out entirely.
# API_INTERNAL_BASE_URL=http://localhost:3000/api/v1

# ---- NextAuth (Auth.js) ----
# Required — NextAuth refuses to boot without it (MissingSecret). Generate:
# openssl rand -base64 32
AUTH_SECRET=replace-with-a-generated-secret
# Only needed off Vercel in production (see infra/docker/.env.vps.example);
# local dev infers it from the request.
# AUTH_URL=http://localhost:3000
