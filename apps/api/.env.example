NODE_ENV=development
APP_NAME=pataspace-api
PORT=3000
APP_BASE_URL=http://localhost:3000
SWAGGER_ENABLED=true
SWAGGER_PATH=docs
SWAGGER_TITLE=PataSpace API
SWAGGER_DESCRIPTION=OpenAPI documentation for the PataSpace backend service.
SWAGGER_VERSION=0.1.0
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pataspace
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
JWT_SECRET=replace-with-a-long-development-secret-value
JWT_REFRESH_SECRET=replace-with-a-long-development-refresh-secret
REFRESH_TOKEN_TRANSPORT=json
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081
REQUEST_ID_HEADER=x-request-id
APP_ENCRYPTION_KEY=replace-with-a-32-char-minimum-encryption-key
IDEMPOTENCY_TTL_SECONDS=86400
IDEMPOTENCY_IN_PROGRESS_TTL_SECONDS=120
RATE_LIMIT_DEFAULT_LIMIT=100
RATE_LIMIT_DEFAULT_TTL_SECONDS=60
QUEUE_PREFIX=pataspace
SMS_PROVIDER=sandbox
STORAGE_PROVIDER=sandbox
MPESA_MODE=sandbox
AT_BASE_URL=https://api.africastalking.com
AWS_S3_BUCKET=pataspace-media
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=local-dev-access-key
AWS_SECRET_ACCESS_KEY=local-dev-secret-key
AWS_S3_PRESIGN_TTL_SECONDS=900
MPESA_BASE_URL=https://sandbox.safaricom.co.ke
MPESA_CONSUMER_KEY=sandbox-consumer-key
MPESA_CONSUMER_SECRET=sandbox-consumer-secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=sandbox-passkey
MPESA_CALLBACK_URL=http://localhost:3000/api/v1/payments/mpesa-callback
MPESA_INITIATOR_NAME=live-initiator-name
MPESA_SECURITY_CREDENTIAL=live-security-credential
MPESA_RESULT_URL=http://localhost:3000/api/v1/payments/mpesa-result
MPESA_TIMEOUT_URL=http://localhost:3000/api/v1/payments/mpesa-timeout
AT_USERNAME=sandbox
AT_API_KEY=replace-with-africas-talking-api-key
