NODE_ENV=development
APP_NAME=pataspace-api
PORT=3000
APP_BASE_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pataspace
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
JWT_SECRET=replace-with-a-long-development-secret-value
JWT_REFRESH_SECRET=replace-with-a-long-development-refresh-secret
REFRESH_TOKEN_TRANSPORT=json
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081
REQUEST_ID_HEADER=x-request-id
APP_ENCRYPTION_KEY=replace-with-a-32-char-minimum-encryption-key
SMS_PROVIDER=sandbox
STORAGE_PROVIDER=sandbox
MPESA_MODE=sandbox
AWS_S3_BUCKET=pataspace-media
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=local-dev-access-key
AWS_SECRET_ACCESS_KEY=local-dev-secret-key
MPESA_BASE_URL=https://sandbox.safaricom.co.ke
MPESA_CONSUMER_KEY=sandbox-consumer-key
MPESA_CONSUMER_SECRET=sandbox-consumer-secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=sandbox-passkey
MPESA_CALLBACK_URL=http://localhost:3000/api/v1/payments/mpesa-callback
AT_USERNAME=sandbox
AT_API_KEY=replace-with-africas-talking-api-key
