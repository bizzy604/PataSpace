{
  "name": "@pataspace/api",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "scripts": {
    "prisma:bootstrap:roles": "ts-node prisma/bootstrap/bootstrap-roles.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "ts-node prisma/bootstrap/run-prisma-with-migration-url.ts migrate deploy",
    "prisma:migrate:dev": "ts-node prisma/bootstrap/run-prisma-with-migration-url.ts migrate dev",
    "prisma:migrate:status": "ts-node prisma/bootstrap/run-prisma-with-migration-url.ts migrate status",
    "prisma:migrate:resolve": "ts-node prisma/bootstrap/run-prisma-with-migration-url.ts migrate resolve",
    "prisma:seed": "prisma db seed",
    "prisma:seed:admin": "ts-node -r dotenv/config prisma/seed-admin.ts",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "build": "nest build",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest --config ./jest.config.ts --runInBand",
    "test:integration": "jest --config ./jest.config.ts --runInBand --testPathPattern=integration",
    "test:watch": "jest --config ./jest.config.ts --watch",
    "test:unit": "jest --config ./jest.config.ts --runInBand --testPathPattern=src",
    "test:e2e": "jest --config ./jest.config.ts --runInBand --testPathPattern=test",
    "test:smoke": "jest --config ./jest.config.ts --runInBand --testPathPattern=smoke",
    "postinstall": "pnpm prisma:generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1079.0",
    "@aws-sdk/s3-request-presigner": "^3.1079.0",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/throttler": "^6.4.0",
    "@pataspace/contracts": "workspace:^",
    "@prisma/client": "^5.22.0",
    "@stellar/stellar-sdk": "^15.1.0",
    "@types/node": "^22.19.15",
    "axios": "^1.18.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.79.2",
    "compression": "^1.8.1",
    "dotenv": "^16.6.1",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "passport": "^0.7.0",
    "passport-custom": "^1.1.1",
    "passport-jwt": "^4.0.1",
    "prisma": "^5.22.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.17.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/testing": "^11.1.17",
    "@types/compression": "^1.8.1",
    "@types/jest": "^29.5.14",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.1"
  }
}
