{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "declaration": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "outDir": "./dist",
    "sourceMap": true,
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@pataspace/contracts": [
        "../../packages/contracts/dist/index.d.ts"
      ],
      "@pataspace/contracts/*": [
        "../../packages/contracts/dist/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts"
  ]
}
