generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum ListingStatus {
  PENDING
  ACTIVE
  UNLOCKED
  CONFIRMED
  COMPLETED
  DELETED
  REJECTED
}

enum ListingHouseType {
  STUDIO
  BEDSITTER
  ONE_BEDROOM
  TWO_BEDROOM
  THREE_BEDROOM
  FOUR_BEDROOM_PLUS
  MANSION
}

enum TransactionType {
  PURCHASE
  SPEND
  REFUND
  BONUS
}

enum PaymentMethod {
  MPESA
  STELLAR
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
  REFUNDED
}

enum CommissionStatus {
  PENDING
  DUE
  PROCESSING
  PAID
  FAILED
  CANCELLED
}

enum ConfirmationSide {
  OUTGOING_TENANT
  INCOMING_TENANT
}

enum SupportTicketStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  CLOSED
}

enum SupportTicketPriority {
  LOW
  MEDIUM
  HIGH
}

enum ReviewerSide {
  INCOMING_TENANT
  OUTGOING_TENANT
}

enum ReferralStatus {
  INVITED
  JOINED
  REWARDED
  EXPIRED
}

enum DisputeStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  CLOSED
}

enum UploadMediaType {
  IMAGE
  VIDEO
}

enum PosterRole {
  OUTGOING_TENANT
  CARETAKER
  LANDLORD
  SCOUT
}

enum UnlockDeadReason {
  OCCUPIED
  FAKE
  UNRESPONSIVE
  LANDLORD_DECLINED
}

enum SuccessFeeStatus {
  PENDING
  PARTIAL
  SETTLED
}

enum ProxySessionStatus {
  ACTIVE
  EXPIRED
}

model User {
  id                   String              @id @default(cuid())
  phoneNumberHash      String?             @unique
  phoneNumberEncrypted String?
  phoneVerified        Boolean             @default(false)
  email                String?             @unique
  passwordHash         String?
  firstName            String
  lastName             String
  role                 Role                @default(USER)
  isActive             Boolean             @default(true)
  isBanned             Boolean             @default(false)
  banReason            String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  lastLoginAt          DateTime?
  credit               Credit?
  creditTransactions   CreditTransaction[]
  listings             Listing[]
  unlocks              Unlock[]
  confirmations        Confirmation[]
  disputes             Dispute[]
  refreshTokens        RefreshToken[]
  uploadedAssets       UploadedAsset[]
  auditLogs            AuditLog[]
  supportTickets       SupportTicket[]
  assignedTickets      SupportTicket[]        @relation("AssignedTickets")
  supportMessages      SupportTicketMessage[] @relation("SupportMessages")
  reviews              UnlockReview[]
  referralsSent        Referral[]        @relation("ReferralsSent")
  referralsReceived    Referral[]        @relation("ReferralsReceived")
  savedListings        SavedListing[]

  @@index([phoneNumberHash])
  @@index([email])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model OTPCode {
  id              String   @id @default(cuid())
  phoneNumberHash String
  codeHash        String
  expiresAt       DateTime
  attempts        Int      @default(0)
  verified        Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([phoneNumberHash, codeHash])
  @@index([expiresAt])
  @@map("otp_codes")
}

model Credit {
  id             String   @id @default(cuid())
  userId         String   @unique
  balance        Int      @default(0)
  lifetimeEarned Int      @default(0)
  lifetimeSpent  Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("credits")
}

model CreditTransaction {
  id                     String            @id @default(cuid())
  userId                 String
  type                   TransactionType
  amount                 Int
  balanceBefore          Int
  balanceAfter           Int
  status                 TransactionStatus @default(PENDING)
  paymentMethod          PaymentMethod     @default(MPESA)
  mpesaReceiptNumber     String?           @unique
  mpesaTransactionId     String?           @unique
  stellarTransactionHash String?           @unique
  phoneNumberHash        String?
  unlockId               String?           @unique
  metadata               Json?
  description            String?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  user                   User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  unlock                 Unlock?           @relation(fields: [unlockId], references: [id])

  @@index([userId, createdAt])
  @@index([status])
  @@index([paymentMethod, status])
  @@index([mpesaTransactionId])
  @@index([phoneNumberHash])
  @@map("credit_transactions")
}

model Listing {
  id                String         @id @default(cuid())
  userId            String
  county            String
  neighborhood      String
  addressEncrypted  String
  latitude          Float
  longitude         Float
  monthlyRent       Int
  bedrooms          Int
  bathrooms         Int
  houseType         ListingHouseType
  propertyType      String
  furnished         Boolean        @default(false)
  description       String         @db.Text
  amenities         String[]
  propertyNotes     String?        @db.Text
  availableFrom     DateTime
  availableTo       DateTime?
  unlockCostCredits Int
  commission        Int
  successFeeKes     Int            @default(0)
  landlordAware     Boolean        @default(false)
  posterRole        PosterRole     @default(OUTGOING_TENANT)
  seededFromConfirmationId String? @unique
  videoUrl          String?
  thumbnailUrl      String?
  status            ListingStatus  @default(PENDING)
  isApproved        Boolean        @default(false)
  approvedAt        DateTime?
  approvedBy        String?
  rejectionReason   String?
  viewCount         Int            @default(0)
  unlockCount       Int            @default(0)
  isDeleted         Boolean        @default(false)
  deletedAt         DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  photos            ListingPhoto[]
  unlocks           Unlock[]
  savedBy           SavedListing[]

  @@index([userId])
  @@index([status, isApproved, isDeleted])
  @@index([county, neighborhood])
  @@index([monthlyRent])
  @@index([availableFrom])
  @@index([createdAt])
  @@index([latitude, longitude])
  @@map("listings")
}

model ListingPhoto {
  id        String    @id @default(cuid())
  listingId String
  url       String
  s3Key     String
  order     Int
  width     Int?
  height    Int?
  latitude  Float?
  longitude Float?
  takenAt   DateTime?
  createdAt DateTime  @default(now())
  listing   Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, order])
  @@map("listing_photos")
}

model UploadedAsset {
  id          String          @id @default(cuid())
  userId       String
  filename     String
  storageKey   String          @unique
  url          String
  cdnUrl       String
  contentType  String
  size         Int
  mediaType    UploadMediaType
  confirmedAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, mediaType, createdAt])
  @@index([confirmedAt])
  @@map("uploaded_assets")
}

model Unlock {
  id                       String             @id @default(cuid())
  listingId                String
  buyerId                  String
  creditsSpent             Int
  revealedPhoneEncrypted   String
  revealedAddressEncrypted String
  revealedGPS              String
  isRefunded               Boolean            @default(false)
  refundReason             String?
  refundedAt               DateTime?
  deadReason               UnlockDeadReason?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  listing                  Listing            @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer                    User               @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  creditTransaction        CreditTransaction?
  confirmations            Confirmation[]
  commission               Commission?
  dispute                  Dispute?
  reviews                  UnlockReview[]
  successFee               SuccessFee?
  proxySession             ProxySession?

  @@unique([listingId, buyerId])
  @@index([buyerId, createdAt])
  @@index([listingId])
  @@map("unlocks")
}

model Confirmation {
  id                String           @id @default(cuid())
  unlockId          String
  userId            String
  side              ConfirmationSide
  confirmedAt       DateTime         @default(now())
  posterPromptSmsAt DateTime?
  unlock      Unlock           @relation(fields: [unlockId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([unlockId, side])
  @@index([unlockId])
  @@index([userId])
  @@map("confirmations")
}

model Commission {
  id                       String           @id @default(cuid())
  unlockId                 String           @unique
  outgoingTenantId         String
  amountKES                Int
  status                   CommissionStatus @default(PENDING)
  mpesaTransactionId       String?          @unique
  mpesaReceiptNumber       String?          @unique
  originatorConversationId String?          @unique
  eligibleAt               DateTime
  paidAt                   DateTime?
  paymentAttempts          Int              @default(0)
  lastAttemptAt            DateTime?
  lastAttemptError         String?
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
  unlock                   Unlock           @relation(fields: [unlockId], references: [id], onDelete: Cascade)

  @@index([status, eligibleAt])
  @@index([outgoingTenantId])
  @@map("commissions")
}

model SuccessFee {
  id               String           @id @default(cuid())
  unlockId         String           @unique
  listingId        String
  moverId          String
  feeDueKes        Int
  creditsApplied   Int              @default(0)
  cashCollectedKes Int              @default(0)
  status           SuccessFeeStatus @default(PENDING)
  settledAt        DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  unlock           Unlock           @relation(fields: [unlockId], references: [id], onDelete: Cascade)

  @@index([moverId, status])
  @@index([listingId])
  @@map("success_fees")
}

model ProxySession {
  id                    String             @id @default(cuid())
  unlockId              String             @unique
  virtualMsisdn         String
  providerRef           String?
  status                ProxySessionStatus @default(ACTIVE)
  expiresAt             DateTime
  firstPosterResponseAt DateTime?
  callCount             Int                @default(0)
  lastCallAt            DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  unlock                Unlock             @relation(fields: [unlockId], references: [id], onDelete: Cascade)

  @@index([virtualMsisdn, status])
  @@index([status, expiresAt])
  @@map("proxy_sessions")
}

model Dispute {
  id         String        @id @default(cuid())
  unlockId   String        @unique
  reportedBy String
  reason     String        @db.Text
  evidence   String[]
  status     DisputeStatus @default(OPEN)
  resolution String?       @db.Text
  resolvedBy String?
  resolvedAt DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  unlock     Unlock        @relation(fields: [unlockId], references: [id], onDelete: Cascade)
  user       User          @relation(fields: [reportedBy], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([reportedBy])
  @@map("disputes")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String
  oldValue   Json?
  newValue   Json?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@index([action])
  @@map("audit_logs")
}

model Referral {
  id              String         @id @default(cuid())
  referrerId      String
  inviteePhoneHash String
  inviteePhoneMasked String
  code            String         @unique
  status          ReferralStatus @default(INVITED)
  refereeUserId   String?
  joinedAt        DateTime?
  rewardedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  referrer        User           @relation("ReferralsSent", fields: [referrerId], references: [id], onDelete: Cascade)
  referee         User?          @relation("ReferralsReceived", fields: [refereeUserId], references: [id], onDelete: SetNull)

  @@unique([referrerId, inviteePhoneHash])
  @@index([referrerId, createdAt])
  @@index([status])
  @@map("referrals")
}

model UnlockReview {
  id        String       @id @default(cuid())
  unlockId  String
  reviewerId String
  side      ReviewerSide
  rating    Int
  comment   String?      @db.Text
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  unlock    Unlock       @relation(fields: [unlockId], references: [id], onDelete: Cascade)
  reviewer  User         @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  @@unique([unlockId, reviewerId])
  @@index([unlockId])
  @@index([reviewerId])
  @@map("unlock_reviews")
}

model SupportTicket {
  id              String                @id @default(cuid())
  userId          String
  subject         String
  message         String                @db.Text
  status          SupportTicketStatus   @default(OPEN)
  priority        SupportTicketPriority @default(MEDIUM)
  assignedToId    String?
  relatedUnlockId String?
  channel         String?
  adminNotes      String?               @db.Text
  resolvedAt      DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedTo      User?                 @relation("AssignedTickets", fields: [assignedToId], references: [id], onDelete: SetNull)
  messages        SupportTicketMessage[]

  @@index([userId, createdAt])
  @@index([status])
  @@index([priority])
  @@index([assignedToId])
  @@map("support_tickets")
}

model SupportTicketMessage {
  id         String        @id @default(cuid())
  ticketId   String
  authorId   String
  authorRole Role
  body       String        @db.Text
  createdAt  DateTime      @default(now())
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author     User          @relation("SupportMessages", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
  @@map("support_ticket_messages")
}

model SavedListing {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId, createdAt])
  @@index([listingId])
  @@map("saved_listings")
}

model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  source    String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("waitlist_entries")
}

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("system_config")
}
