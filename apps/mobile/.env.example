# Local development environment for apps/mobile (copy to .env; never commit .env).
# For EAS cloud builds these live as EAS environment variables instead — see
# apps/mobile/STORE_RELEASE.md. EXPO_PUBLIC_* values are inlined into the bundle
# at build time, so they must be present in the build environment.

# Public base URL of the PataSpace API, including the /api/v1 prefix.
# Local: http://<your-LAN-ip>:3001/api/v1 — Store builds: https://api.<domain>/api/v1
EXPO_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1

# Clerk publishable key. Use a pk_test_ key locally and a pk_live_ key for production.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY="your_clerk_publishable_key"

# Android Google Maps SDK key (injected into the native build by app.config.ts).
GOOGLE_MAPS_API_KEY=your_google_maps_android_key
